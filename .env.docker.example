APP_NAME="Contratación Abierta"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://tu-dominio.example.com

# Marca del sitio público (se usa en los informes PDF, etc.). Por defecto: contratacionabierta.com
# SITIO_NOMBRE="Contratación Abierta"
# SITIO_DOMINIO=contratacionabierta.com
# SITIO_URL=https://contratacionabierta.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Base de datos (producción: PostgreSQL 17)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=contratacion
DB_USERNAME=contratacion
DB_PASSWORD=__CAMBIAR__

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log

# Restringir acceso al panel de administración por IP.
# Nunca usar 0.0.0.0/0 en producción.
ADMIN_ALLOWED_IPS=127.0.0.1,::1
